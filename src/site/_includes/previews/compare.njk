<div class="q2w-compare" style="position:absolute; inset:24px; border-radius:12px; overflow:hidden; border:1px solid var(--q2w-border); background:var(--q2w-surface);">
  <div class="q2w-compare__before" style="position:absolute; inset:0; background:linear-gradient(135deg,#dbeafe,#bfdbfe);"><span style="position:absolute;left:12px;top:12px;font-size:11px;font-family:var(--q2w-font-mono);">Before</span></div>
  <div class="q2w-compare__after" style="position:absolute; inset:0; width:52%; background:linear-gradient(135deg,#fed7aa,#f97316);"><span style="position:absolute;left:12px;top:12px;font-size:11px;font-family:var(--q2w-font-mono);">After</span></div>
  <div class="q2w-compare__handle" style="left:52%;">⇆</div>
</div>
