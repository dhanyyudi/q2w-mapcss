<div class="q2w-filter q2w-filter--floating" style="width:300px;">
  <div class="q2w-filter__head">
    <div>
      <div class="q2w-filter__title">Parcel filter</div>
      <div class="q2w-filter__sub">Cirebon Land Value</div>
    </div>
    <span class="q2w-filter__count" data-doc-filter-count>2 active</span>
  </div>
  <label class="q2w-filter__row"><input type="checkbox" checked data-doc-filter> Value above Rp 1B</label>
  <label class="q2w-filter__row"><input type="checkbox" checked data-doc-filter> Inside collector road buffer</label>
  <label class="q2w-filter__row"><input type="checkbox" data-doc-filter> Only river-adjacent parcels</label>
  <button class="q2w-btn q2w-btn--primary q2w-btn--sm">Apply</button>
</div>
