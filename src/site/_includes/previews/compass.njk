<div class="doc-map-preview" style="min-height:220px;">
  <div class="doc-map-preview__tiles doc-map-preview__tiles--terrain"></div>
  <div class="doc-map-preview__overlay"></div>
  <div class="doc-map-preview__controls" style="place-items: stretch;">
    <div style="display:flex; justify-content:space-between; align-items:flex-start; width:100%; height:100%;">
      <div class="q2w-scale q2w-scale--bar"><div class="q2w-scale__bar"></div><div class="q2w-scale__label">1 km</div></div>
      <div style="display:grid; gap:10px; justify-items:end;">
        <div class="q2w-compass q2w-compass--ring"><span class="q2w-compass__n">N</span><div class="q2w-compass__needle"></div></div>
        <div class="q2w-compass q2w-compass--bearing"><span>Bearing</span><strong class="q2w-compass__bearing">032°</strong></div>
      </div>
    </div>
  </div>
</div>
