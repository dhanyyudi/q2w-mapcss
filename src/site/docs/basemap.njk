  <h2>Suggested sources</h2>
  <table class="doc-table">
    <thead><tr><th>Style</th><th>Suggested provider</th></tr></thead>
    <tbody>
      <tr><td><code>Streets</code></td><td>OpenStreetMap standard tiles</td></tr>
      <tr><td><code>Light</code></td><td>Carto Positron / light-gray tiles</td></tr>
      <tr><td><code>Terrain</code></td><td>Esri World Terrain base + reference labels if needed</td></tr>
