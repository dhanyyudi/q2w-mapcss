<section class="doc-section">
  <h2>Usage</h2>
  <div class="doc-code"><button class="doc-copy">copy</button><pre>&lt;div class="q2w-basemap-panel"&gt;
  &lt;div class="q2w-basemap-panel__head"&gt;
    &lt;div&gt;
      &lt;div class="q2w-basemap-panel__title"&gt;Basemap&lt;/div&gt;
      &lt;div class="q2w-basemap-panel__sub"&gt;Southeast Asia preview&lt;/div&gt;
    &lt;/div&gt;
    &lt;span class="q2w-basemap-panel__active"&gt;OSM Streets&lt;/span&gt;
  &lt;/div&gt;
  &lt;div class="q2w-basemap-grid q2w-basemap-grid--tiles"&gt;
    &lt;button class="q2w-basemap q2w-basemap--preview q2w-basemap--active"&gt;
      &lt;div class="q2w-basemap__thumb q2w-bm-osm"&gt;&lt;/div&gt;
      &lt;div class="q2w-basemap__meta"&gt;...&lt;/div&gt;
    &lt;/button&gt;
  &lt;/div&gt;
&lt;/div&gt;</pre></div>
</section>

