<script>
(function () {
  if (!window.L) return;
  const mapEl = document.getElementById('docs-basemap-map');
  if (!mapEl || mapEl.dataset.ready) return;
  mapEl.dataset.ready = 'true';
  const map = L.map(mapEl, { zoomControl: false, attributionControl: false, dragging: false, scrollWheelZoom: false, doubleClickZoom: false, boxZoom: false, keyboard: false, tap: false }).setView([-6.7797, 108.4714], 13);
  const layers = {
    osm: L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }),
    light: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { subdomains: 'abcd', maxZoom: 20 }),
    terrain: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Terrain_Base/MapServer/tile/{z}/{y}/{x}', { maxZoom: 13 }),
    imagery: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { maxZoom: 20 })
  };
  let active = layers.osm.addTo(map);
  document.addEventListener('click', (event) => {
    const button = event.target.closest('[data-doc-tile]');
    if (!button) return;
    const next = layers[button.dataset.docTile];
    if (!next || next === active) return;
    map.removeLayer(active);
    active = next.addTo(map);
  });
})();
</script>

