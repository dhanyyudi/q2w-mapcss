<h1 class="doc-h1">Basemap</h1>
<p class="doc-lead">Basemap picker with real tile-backed mini previews for common WebGIS defaults.</p>

<section class="doc-section">
  <h2>Preview</h2>
  <div class="doc-preview" style="padding:24px; min-height: 360px; place-items: stretch;">
    <div class="q2w-basemap-demo">
      <div id="docs-basemap-map" style="height: 220px; border-radius: 12px; overflow: hidden; border: 1px solid var(--q2w-border);"></div>
      <div class="q2w-basemap-demo__caption">Active basemap: <strong data-doc-basemap-label>OSM Streets</strong></div>
      <div class="q2w-basemap-grid q2w-basemap-grid--compact">
        <button class="q2w-basemap q2w-basemap--active" data-doc-basemap="OSM Streets" data-doc-tile="osm"><div class="q2w-basemap__thumb q2w-bm-osm"></div><div class="q2w-basemap__label">OSM Streets</div></button>
        <button class="q2w-basemap" data-doc-basemap="Carto Light" data-doc-tile="light"><div class="q2w-basemap__thumb q2w-bm-carto-light"></div><div class="q2w-basemap__label">Carto Light</div></button>
        <button class="q2w-basemap" data-doc-basemap="Esri Terrain" data-doc-tile="terrain"><div class="q2w-basemap__thumb q2w-bm-esri-terrain"></div><div class="q2w-basemap__label">Esri Terrain</div></button>
        <button class="q2w-basemap" data-doc-basemap="Esri Imagery" data-doc-tile="imagery"><div class="q2w-basemap__thumb q2w-bm-esri-imagery"></div><div class="q2w-basemap__label">Esri Imagery</div></button>
