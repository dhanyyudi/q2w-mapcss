component: "toast"
permalink: "/docs/toast.html"
extraScripts: |
  <script src="../dist/q2w-interactions.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll("[data-doc-toast]").forEach((button) => {
        button.addEventListener("click", () => {
          window.q2w.toast(button.dataset.docToastMessage, button.dataset.docToastType, 1600);
        });
      });
    });
  </script>
