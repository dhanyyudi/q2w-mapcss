---
permalink: "/examples/poi.html"
layout: example.njk
title: "POI example — Zona Nilai Tanah"
extraHead: |
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.Default.css">
  <style>
    html, body { height: 100%; margin: 0; }
    #map { position: absolute; inset: 0; }
    .poi-pin { width: 16px; height: 16px; border-radius: 999px; background: var(--q2w-accent); border: 3px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,.18); }
  </style>
---
{% include "nav-example.njk" %}
<div class="q2w-header" style="position: absolute; top: 54px; left: 12px; right: 12px; z-index: 600;">
  <div class="q2w-header__brand"><div class="q2w-header__logo">q2</div><div><div class="q2w-header__title">POI & clusters — Zona Nilai Tanah</div><div class="q2w-header__sub">Cirebon · village centroids grouped for discovery</div></div></div>
</div>
<div id="map"></div>
<div class="q2w-footer"><div class="q2w-footer__group">© 2026 Aksara Lab · Powered by q2w-mapcss</div><div class="q2w-footer__push"></div><div class="q2w-footer__group q2w-footer__coord" id="coords">0.0000, 0.0000</div></div>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
<script>
const map = L.map('map').setView([-6.7797, 108.4714], 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
fetch('_data/znt.geojson').then(r => r.json()).then(data => {
  L.geoJSON(data.zones, { style: { fillColor: '#0f7a78', fillOpacity: 0.08, color: '#0f7a78', weight: 1 } }).addTo(map);
  const cluster = L.markerClusterGroup();
  data.villages.features.forEach(f => {
    const [lng, lat] = f.geometry.coordinates;
    const icon = L.divIcon({ className: '', html: '<div class="poi-pin"></div>', iconSize: [16,16] });
    const marker = L.marker([lat, lng], { icon });
    marker.bindPopup(`<div class="q2w-popup__header"><div><div class="q2w-popup__title">${f.properties.name}</div><div class="q2w-popup__sub">${f.properties.code}</div></div></div><div class="q2w-attr"><span class="q2w-attr__key">value</span><span class="q2w-attr__val">${Number(f.properties.value).toLocaleString()}</span></div>`);
    cluster.addLayer(marker);
  });
  map.addLayer(cluster);
});
map.on('mousemove', e => {
  document.getElementById('coords').textContent = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
});
</script>
