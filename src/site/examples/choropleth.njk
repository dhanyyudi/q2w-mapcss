---
permalink: "/examples/choropleth.html"
layout: example.njk
title: "Choropleth example — Zona Nilai Tanah"
extraHead: |
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <style>
    html, body { height: 100%; margin: 0; }
    #map { position: absolute; inset: 0; }
    @media (max-width: 640px) {
      .ex-back { top: auto !important; bottom: 44px !important; left: 12px !important; z-index: 800; }
      .q2w-panel { right: 12px !important; left: 12px !important; width: auto !important; }
    }
  </style>
---
{% include "nav-example.njk" %}
<div class="q2w-header" style="position: absolute; top: 54px; left: 12px; right: 12px; z-index: 600;">
  <div class="q2w-header__brand">
    <div class="q2w-header__logo">q2</div>
    <div>
      <div class="q2w-header__title">Choropleth — Zona Nilai Tanah</div>
      <div class="q2w-header__sub">Cirebon · graduated by land value</div>
    </div>
  </div>
</div>
<div id="map"></div>
<div class="q2w-panel" style="position: absolute; top: 130px; right: 12px; z-index: 600; width: 220px;">
  <div class="q2w-panel__header">Legend</div>
  <div class="q2w-panel__body">
    <div class="q2w-legend-row"><span class="q2w-legend-swatch" style="background: var(--q2w-seq-1);"></span><span>&lt; 100k</span></div>
    <div class="q2w-legend-row"><span class="q2w-legend-swatch" style="background: var(--q2w-seq-2);"></span><span>100k – 500k</span></div>
    <div class="q2w-legend-row"><span class="q2w-legend-swatch" style="background: var(--q2w-seq-3);"></span><span>500k – 1M</span></div>
    <div class="q2w-legend-row"><span class="q2w-legend-swatch" style="background: var(--q2w-seq-4);"></span><span>1M – 2M</span></div>
    <div class="q2w-legend-row"><span class="q2w-legend-swatch" style="background: var(--q2w-seq-5);"></span><span>2M – 5M</span></div>
    <div class="q2w-legend-row"><span class="q2w-legend-swatch" style="background: var(--q2w-seq-6);"></span><span>&gt; 5M</span></div>
  </div>
</div>
<div class="q2w-footer">
  <div class="q2w-footer__group">© 2026 Aksara Lab · Powered by q2w-mapcss</div>
  <div class="q2w-footer__push"></div>
  <div class="q2w-footer__group q2w-footer__coord" id="coords">0.0000, 0.0000</div>
</div>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const map = L.map('map').setView([-6.7797, 108.4714], 13);
L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' }).addTo(map);
function colorFor(v) {
  const css = getComputedStyle(document.documentElement);
  if (v < 100000) return css.getPropertyValue('--q2w-seq-1');
  if (v < 500000) return css.getPropertyValue('--q2w-seq-2');
  if (v < 1000000) return css.getPropertyValue('--q2w-seq-3');
  if (v < 2000000) return css.getPropertyValue('--q2w-seq-4');
  if (v < 5000000) return css.getPropertyValue('--q2w-seq-5');
  return css.getPropertyValue('--q2w-seq-6');
}
fetch('_data/znt.geojson').then(r => r.json()).then(data => {
  L.geoJSON(data.zones, {
    style: f => ({ fillColor: colorFor(f.properties.value), fillOpacity: 0.75, color: '#fff', weight: 1 }),
    onEachFeature: (f, layer) => {
      layer.bindPopup(`
        <div class="q2w-popup__header"><div><div class="q2w-popup__title">${f.properties.name}</div><div class="q2w-popup__sub">${f.properties.code}</div></div></div>
        <div class="q2w-attr"><span class="q2w-attr__key">value</span><span class="q2w-attr__val">${Number(f.properties.value).toLocaleString()}</span></div>
        <div class="q2w-attr"><span class="q2w-attr__key">area</span><span class="q2w-attr__val">${f.properties.area} ha</span></div>
      `);
    }
  }).addTo(map);
  L.geoJSON(data.roads, { style: { color: '#facc15', weight: 3 } }).addTo(map);
  L.geoJSON(data.rivers, { style: { color: '#38bdf8', weight: 2 } }).addTo(map);
});
map.on('mousemove', e => {
  document.getElementById('coords').textContent = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
});
</script>
