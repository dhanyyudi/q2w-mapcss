---
permalink: "/examples/dashboard.html"
layout: example.njk
title: "Dashboard example — Zona Nilai Tanah"
extraHead: |
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <style>
    html, body { height: 100%; margin: 0; }
    #map { position: absolute; inset: 0 360px 0 0; }
    .db-side { position: absolute; top: 0; right: 0; bottom: 0; width: 360px; background: var(--q2w-surface); border-left: 1px solid var(--q2w-border); z-index: 500; overflow: auto; }
    .db-side__head { padding: 88px 20px 16px; border-bottom: 1px solid var(--q2w-border); }
    .db-side__body { padding: 16px 20px 96px; }
    .db-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .db-stat { padding: 12px; background: var(--q2w-surface-soft); border-radius: var(--q2w-radius-md); }
    .db-stat__k { font-family: var(--q2w-font-mono); font-size: 10px; color: var(--q2w-text-faint); text-transform: uppercase; }
    .db-stat__v { font-size: 22px; font-weight: 700; margin-top: 4px; }
    .db-list { margin-top: 18px; display: grid; gap: 10px; }
    .db-row { display: flex; justify-content: space-between; gap: 8px; padding-bottom: 8px; border-bottom: 1px dashed var(--q2w-border); font-size: 13px; }
    @media (max-width: 900px) {
      #map { inset: 0; }
      .db-side { position: absolute; left: 12px; right: 12px; bottom: 56px; top: auto; width: auto; height: 260px; border: 1px solid var(--q2w-border); border-radius: var(--q2w-radius-lg); }
      .db-side__head { padding-top: 16px; }
    }
  </style>
---
{% include "nav-example.njk" %}
<div class="q2w-header" style="position: absolute; top: 54px; left: 12px; right: 372px; z-index: 600;">
  <div class="q2w-header__brand"><div class="q2w-header__logo">q2</div><div><div class="q2w-header__title">Dashboard — Zona Nilai Tanah</div><div class="q2w-header__sub">Cirebon · same dataset, analysis layout</div></div></div>
</div>
<div id="map"></div>
<aside class="db-side">
  <div class="db-side__head">
    <div style="font-weight:700; font-size:18px;">Land value dashboard</div>
    <div style="font-size:13px; color:var(--q2w-text-muted); margin-top:4px;">Metrics derived from the same Zona Nilai Tanah dataset.</div>
  </div>
  <div class="db-side__body">
    <div class="db-grid">
      <div class="db-stat"><div class="db-stat__k">zones</div><div class="db-stat__v" id="statZones">0</div></div>
      <div class="db-stat"><div class="db-stat__k">mean</div><div class="db-stat__v" id="statMean">0</div></div>
      <div class="db-stat"><div class="db-stat__k">max</div><div class="db-stat__v" id="statMax">0</div></div>
      <div class="db-stat"><div class="db-stat__k">roads</div><div class="db-stat__v" id="statRoads">0</div></div>
    </div>
    <h3 style="margin:20px 0 10px; font-size:14px;">Top 5 zones</h3>
    <div class="db-list" id="topZones"></div>
  </div>
</aside>
<div class="q2w-footer"><div class="q2w-footer__group">© 2026 Aksara Lab · Powered by q2w-mapcss</div><div class="q2w-footer__push"></div><div class="q2w-footer__group q2w-footer__coord" id="coords">0.0000, 0.0000</div></div>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const map = L.map('map').setView([-6.7797, 108.4714], 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
fetch('_data/znt.geojson').then(r => r.json()).then(data => {
  const zones = data.zones.features;
  const values = zones.map(f => Number(f.properties.value));
  document.getElementById('statZones').textContent = zones.length;
  document.getElementById('statMean').textContent = Math.round(values.reduce((a,b)=>a+b,0) / values.length).toLocaleString();
  document.getElementById('statMax').textContent = Math.max(...values).toLocaleString();
  document.getElementById('statRoads').textContent = data.roads.features.length;
  const top = [...zones].sort((a,b)=>b.properties.value-a.properties.value).slice(0,5);
  document.getElementById('topZones').innerHTML = top.map(f => `<div class="db-row"><span>${f.properties.name}</span><strong>${Number(f.properties.value).toLocaleString()}</strong></div>`).join('');
  L.geoJSON(data.zones, {
    style: { fillColor: '#0f7a78', fillOpacity: 0.25, color: '#ffffff', weight: 1 },
    onEachFeature: (f, layer) => layer.bindPopup(`<div class="q2w-popup__header"><div><div class="q2w-popup__title">${f.properties.name}</div><div class="q2w-popup__sub">${f.properties.code}</div></div></div><div class="q2w-attr"><span class="q2w-attr__key">value</span><span class="q2w-attr__val">${Number(f.properties.value).toLocaleString()}</span></div>`)
  }).addTo(map);
  L.geoJSON(data.roads, { style: { color: '#f59e0b', weight: 3 } }).addTo(map);
  L.geoJSON(data.rivers, { style: { color: '#38bdf8', weight: 2 } }).addTo(map);
});
map.on('mousemove', e => {
  document.getElementById('coords').textContent = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
});
</script>
