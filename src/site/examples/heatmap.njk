---
permalink: "/examples/heatmap.html"
layout: example.njk
title: "Heatmap example — Zona Nilai Tanah"
extraHead: |
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <style>
    html, body { height: 100%; margin: 0; }
    #map { position: absolute; inset: 0; }
    @media (max-width: 640px) { .ex-back { top: auto !important; bottom: 44px !important; left: 12px !important; z-index: 800; } }
  </style>
---
{% include "nav-example.njk" %}
<div class="q2w-header" style="position: absolute; top: 54px; left: 12px; right: 12px; z-index: 600;">
  <div class="q2w-header__brand"><div class="q2w-header__logo">q2</div><div><div class="q2w-header__title">Heatmap — Zona Nilai Tanah</div><div class="q2w-header__sub">Cirebon · centroid density weighted by value</div></div></div>
</div>
<div id="map"></div>
<div class="q2w-panel" style="position:absolute; right:12px; top:130px; width:240px; z-index:600;"><div class="q2w-panel__header">Heat intensity</div><div class="q2w-panel__body"><div class="q2w-grad" style="background:linear-gradient(90deg,#2563eb,#22c55e,#facc15,#ef4444);"></div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--q2w-text-muted);margin-top:8px;"><span>low</span><span>high</span></div></div></div>
<div class="q2w-footer"><div class="q2w-footer__group">© 2026 Aksara Lab · Powered by q2w-mapcss</div><div class="q2w-footer__push"></div><div class="q2w-footer__group q2w-footer__coord" id="coords">0.0000, 0.0000</div></div>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
<script>
const map = L.map('map').setView([-6.7797, 108.4714], 13);
L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' }).addTo(map);
fetch('_data/znt.geojson').then(r => r.json()).then(data => {
  L.geoJSON(data.zones, { style: { fillOpacity: 0.08, color: '#fff', weight: 1 } }).addTo(map);
  const points = data.villages.features.map(f => [f.geometry.coordinates[1], f.geometry.coordinates[0], f.properties.intensity || 0.5]);
  L.heatLayer(points, { radius: 25, blur: 18, maxZoom: 15 }).addTo(map);
});
map.on('mousemove', e => {
  document.getElementById('coords').textContent = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
});
</script>
