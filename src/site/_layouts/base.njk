<!DOCTYPE html>
<html lang="en"{% if theme %} data-theme="{{ theme }}"{% endif %}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title }} — q2w-mapcss</title>
<link rel="stylesheet" href="{{ cssPath | default('dist/q2w-mapcss.css') }}" />
{% if showcaseCss %}<link rel="stylesheet" href="dist/q2w-mapcss.showcase.css" />{% endif %}
{% if extraHead %}{{ extraHead | safe }}{% endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

{{ content | safe }}

</body>
</html>
